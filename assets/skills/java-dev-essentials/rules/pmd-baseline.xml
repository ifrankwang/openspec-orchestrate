<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="openspec-orchestrate-baseline"
    xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.net/ruleset_2_0_0.xsd">

    <description>OpenSpec Orchestrate 基准 PMD 规则集。项目 src/main/resources/pmd-rules.xml 须至少包含本文件所有规则，可按需扩展。</description>

    <!-- 禁止 System.out.println / System.err.println -->
    <rule ref="category/java/bestpractices.xml/SystemPrintln"/>

    <!-- 强制 try-with-resources -->
    <rule ref="category/java/errorprone.xml/CloseResource"/>

    <!-- 方法行数上限 100 -->
    <rule ref="category/java/design.xml/NcssCount">
        <properties>
            <property name="methodReportLevel" value="100"/>
        </properties>
    </rule>

    <!-- NPath 复杂度上限 200 -->
    <rule ref="category/java/design.xml/NPathComplexity">
        <properties>
            <property name="reportLevel" value="200"/>
        </properties>
    </rule>

    <!-- 避免空 catch 块 -->
    <rule ref="category/java/errorprone.xml/EmptyCatchBlock"/>

    <!-- 避免捕获异常后直接重抛的冗余死代码模式 -->
    <rule ref="category/java/design.xml/AvoidRethrowingException"/>

    <!-- 避免空的控制语句（if/while/for 等） -->
    <rule ref="category/java/codestyle.xml/EmptyControlStatement"/>

    <!-- 避免未使用的局部变量 -->
    <rule ref="category/java/bestpractices.xml/UnusedLocalVariable"/>

    <!-- 避免未使用的私有方法 -->
    <rule ref="category/java/bestpractices.xml/UnusedPrivateMethod"/>

    <!-- 避免无用的 import（含未使用、重复、* 导入但未使用等） -->
    <rule ref="category/java/codestyle.xml/UnnecessaryImport"/>

    <!-- 类圈复杂度上限 20（标准阈值）；若类因架构模式固有偏高（仓储薄委托 / 编排器多分叉），
         以 @SuppressWarnings("PMD.CyclomaticComplexity") 显式豁免并注明理由 -->
    <rule ref="category/java/design.xml/CyclomaticComplexity">
        <properties>
            <property name="classReportLevel" value="20"/>
            <property name="methodReportLevel" value="15"/>
        </properties>
    </rule>

    <!-- 避免过于长的变量名 -->
    <rule ref="category/java/codestyle.xml/LongVariable">
        <properties>
            <property name="minimum" value="40"/>
        </properties>
    </rule>

    <!-- 简化布尔表达式 -->
    <rule ref="category/java/design.xml/SimplifyBooleanExpressions"/>

    <!-- 禁止不必要的内联全限定名：无类名冲突时应使用 import 后简洁类名 -->
    <rule ref="category/java/codestyle.xml/UnnecessaryFullyQualifiedName"/>
</ruleset>
